# Copy this file to .env and adjust as needed.
# For local development the defaults below are fine; CHANGE all secrets in production.

# --- Secrets (override in production) ---
JWT_SECRET=dev-jwt-secret-change-me
TICKET_SECRET=dev-ticket-secret-change-me
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Argon2id password hashing (memory-hard; aligned with SCALE.md, m = 46 MiB) ---
ARGON2_TIME_COST=1
ARGON2_MEMORY_COST=47104
ARGON2_PARALLELISM=1

# --- Spike protection: max concurrent password hashes (the SCALE.md bounded pool) ---
HASH_CONCURRENCY=3

# --- Event configuration ---
EVENT_NAME=TechFest 2026
CAPACITY=500
TICKET_PRICE=50000          # in paise (= 500.00 INR)
CURRENCY=INR

# --- Rate limits (slowapi syntax) ---
RATE_LIMIT_REGISTER=10/minute
RATE_LIMIT_LOGIN=20/minute

# --- Database ---
DATABASE_URL=sqlite:///./techfest.db
